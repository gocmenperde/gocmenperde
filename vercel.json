{
  "outputDirectory": ".",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/cayma-kosullari",
      "destination": "/iade-politikasi.html"
    },
    {
      "source": "/cayma-kosullari.html",
      "destination": "/iade-politikasi.html"
    },
    {
      "source": "/mesafeli-satis",
      "destination": "/mesafeli-satis.html"
    },
    {
      "source": "/mesafeli-satis-sozlesmesi",
      "destination": "/mesafeli-satis.html"
    },
    {
      "source": "/iade-politikasi",
      "destination": "/iade-politikasi.html"
    },
    {
      "source": "/gizlilik-politikasi",
      "destination": "/gizlilik-politikasi.html"
    },
    {
      "source": "/hesapim",
      "destination": "/hesabim.html"
    },
    {
      "source": "/hesap",
      "destination": "/hesap.html"
    },
    {
      "source": "/admin",
      "destination": "/admin.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)\\.(webp|avif|jpg|jpeg|png|svg|woff2|ico)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)\\.(css|js)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, must-revalidate"
        }
      ]
    },
    {
      "source": "/(index\\.html|hesabim\\.html|hesap\\.html)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
